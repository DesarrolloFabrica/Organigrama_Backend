# Variables de entorno (copiar a `.env` en esta carpeta)

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=core
# Opcional: search_path por defecto. Las entidades usan schema `core` y `organigrama`.
# DB_SCHEMA=

# IP publica de Cloud SQL (solo si la red lo permite). En Cloud Run suele hacer TIMEOUT:
# DB_HOST=136.113.128.135
# DB_SSL=true
#
# Recomendado en Cloud Run: vincular la instancia en el servicio y usar socket:
#   gcloud run services update SERVICIO --add-cloudsql-instances=PROYECTO:REGION:INSTANCIA
# DB_HOST=/cloudsql/it-fab-contenido-edu-5:us-central1:TU_INSTANCIA
# DB_SSL=false

# En desarrollo puede ser `true`. En producción (Cloud Run) debe ser `false`.
DB_SYNCHRONIZE=false
DB_LOGGING=false

NODE_ENV=production
CORS_ORIGIN=https://tu-frontend.run.app
# Cloud Run inyecta PORT=8080; en local no hace falta definirlo.

# --- Endpoints legacy del organigrama ---
# true (o ausente): mantiene GET /api/org-chart y GET /api/org-chart/team/:id disponibles.
# false: los bloquea con 410 Gone; usar /api/org-chart/root, /node/:id y /children/:id.
ORG_CHART_LEGACY_ENABLED=true

# --- Fotos organigrama ---
# ORG_CHART_PHOTOS_ENABLED=false
# API_PUBLIC_BASE_URL=http://localhost:3000
# ORG_CHART_PHOTO_CACHE_TTL_MS=86400000
# ORG_CHART_PHOTO_NEGATIVE_CACHE_TTL_MS=3600000
# ORG_CHART_PHOTO_FETCH_CONCURRENCY=5
# ORG_CHART_PHOTO_TEST_URL=https://i.pravatar.cc/256?u=organigrama-root

# --- Google Workspace fotos (requiere DWD aprobado; Fase B) ---
# GOOGLE_WORKSPACE_PHOTOS_ENABLED=false

# --- Login Google (colaboradores @cun.edu.co registrados en Core) ---
# GOOGLE_CLIENT_ID=550902908078-fvabjtle954fqr6alhofdv7fvvr4bcbv.apps.googleusercontent.com
# AUTH_JWT_SECRET=cambiar-en-produccion-min-32-caracteres
# AUTH_JWT_EXPIRES_IN=7d

# --- Onboarding perfil (Fase 1) ---
# Ejecutar en Cloud SQL:
#   migrations/001_person_profile_state.sql
#   migrations/003_core_person_emergency_contact.sql
# PROFILE_DEV_RESET_ENABLED=true
# PROFILE_DEV_RESET_ALLOWED_EMAILS=jose_camachoc@cun.edu.co

# --- Fase 0: diagnóstico Google Workspace (NO activar en producción) ---
# GOOGLE_WORKSPACE_PHOTO_DIAG_ENABLED=true
# GOOGLE_WORKSPACE_PHOTO_DIAG_ALLOW_IN_PRODUCTION=false
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/google-service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}
# GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@institucion.edu
