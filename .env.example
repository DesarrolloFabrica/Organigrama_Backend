# Variables de entorno (copiar a `.env` en esta carpeta)
# PostgreSQL local — alinear con `docker-compose.yml` si lo usas.

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=organigrama

# En desarrollo suele ser `true` para crear/actualizar tablas desde entidades.
# En producción debe ser `false` y aplicar migraciones explícitas.
DB_SYNCHRONIZE=true

# Log SQL de TypeORM (ruidoso; útil al depurar)
DB_LOGGING=true
